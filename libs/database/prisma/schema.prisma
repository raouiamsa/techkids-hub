// 1. Configuration de base
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
//  PHASE 0-1 : NOYAU SYSTÈME (User, Auth, Profile)
// ═══════════════════════════════════════════════════════════════

enum UserRole {
  PARENT
  STUDENT
  TEACHER
  ADMIN
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  role          UserRole @default(STUDENT)

  isEmailVerified         Boolean   @default(false)
  emailVerificationToken  String?
  emailVerificationExpires DateTime?

  refreshToken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile?

  students User[]  @relation("ParentStudents")
  parent   User?   @relation("ParentStudents", fields: [parentId], references: [id])
  parentId String?

  taughtCourses Course[]      @relation("teacher_courses")
  enrollments   Enrollment[]
  progressions  Progression[]
  submissions   Submission[]

  // Relation pour les brouillons générés par l'IA
  reviewedDrafts GeneratedDraft[] @relation("DraftReviewer")
}

model Profile {
  id      String @id @default(uuid())
  userId  String @unique
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName   String
  lastName    String
  phoneNumber String?
  address     String?
  avatar      String?
  dateOfBirth DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════
//  PHASE 2 : EDU-TRACKER & LMS
// ═══════════════════════════════════════════════════════════════

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ExerciseType {
  QUIZ
  CIRCUIT_BUILD
  CODE_CHALLENGE
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model Course {
  id              String      @id @default(uuid())
  title           String
  description     String?
  level           CourseLevel @default(BEGINNER)
  
  // Données pédagogiques structurées (QCM & Projets)
  placementBank     Json?       // Test de diagnostic initial
  certificationBank Json?       // Examen final de certification
  finalProject      Json?       // Énoncé et corrigé du projet de synthèse
  
  isPublished     Boolean     @default(false)
  imageUrl        String?

  teacherId String
  teacher   User      @relation("teacher_courses", fields: [teacherId], references: [id])

  modules      Module[]
  enrollments  Enrollment[]
  
  // Sources de connaissances liées
  contentSources ContentSource[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Module {
  id      String  @id @default(uuid())
  title   String
  order   Int
  content String? @db.Text // Contenu principal du module en Markdown

  courseId     String
  course       Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  exercises    Exercise[]
  progressions Progression[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId, order])
}

model Exercise {
  id           String       @id @default(uuid())
  title        String
  instructions String
  exerciseType ExerciseType @default(QUIZ)
  solution     String?      // Code ou réponse attendue pour correction IA

  moduleId    String
  module      Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  submissions Submission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Enrollment {
  id         String           @id @default(uuid())
  status     EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime         @default(now())

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
}

model Progression {
  id                String         @id @default(uuid())
  completionPercent Float          @default(0)
  status            ProgressStatus @default(NOT_STARTED)
  completedAt       DateTime?

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@unique([studentId, moduleId])
}

model Submission {
  id          String   @id @default(uuid())
  answer      String
  score       Float?
  attempt     Int      @default(1)
  submittedAt DateTime @default(now())

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════
//  PHASE 4 : CONTENT GENERATION & AI (Pipeline Archiviste & Sophie)
// ═══════════════════════════════════════════════════════════════

enum SourceType {
  PDF
  YOUTUBE
  WEBPAGE
}

enum IndexingStatus {
  INDEXING  // En cours de vectorisation dans ChromaDB
  READY     // Prêt pour la génération
  ERROR     // Échec technique
}

enum DraftStatus {
  PROCESSING      // IA en train de rédiger
  PENDING_REVIEW  // Attente de validation professeur
  APPROVED        // Validé et transformé en modules
  REJECTED        // Supprimé ou ignoré
}

model ContentSource {
  id             String         @id @default(uuid())
  title          String
  type           SourceType     @default(PDF)
  url            String?        @unique
  
  // Suivi de la progression de l'ingestion (Archiviste)
  indexingStatus IndexingStatus @default(INDEXING)
  progressPercent Int           @default(0)

  courseId       String?
  course         Course?        @relation(fields: [courseId], references: [id])
  
  drafts         GeneratedDraft[]
  createdAt      DateTime       @default(now())
}

model GeneratedDraft {
  id            String      @id @default(uuid())
  title         String?     // Titre proposé par l'IA
  language      String?     // Langage technique détecté (ex: Python)
  
  // Structure complète générée (Syllabus, Modules, Projets)
  syllabus      Json?
  content       Json?       @db.JsonB // Modules + Exercices + SOLUTIONS détaillées
  
  placementBank     Json?       // Diagnostic généré
  certificationBank Json?       // Examen de sortie généré
  finalProject      Json?       // Projet final généré

  status         DraftStatus @default(PENDING_REVIEW)
  progressPercent Int         @default(0) // Progression globale (Architecte -> Writer -> Critic)
  aiScore        Int?        // Score qualité 0-100 calculé par Llama 3.3 (Critique)
  
  teacherId String
  teacher   User        @relation("DraftReviewer", fields: [teacherId], references: [id])
  
  // On utilise SetNull pour garder le brouillon même si la source originale est supprimée
  sourceId  String?
  source    ContentSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}